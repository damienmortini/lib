{
  "name": "@damienmortini/lib",
  "version": "0.2.13",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/**/*"
  ],
  "scripts": {
    "build": "npx nx run-many --target=build",
    "build:watch": "npx nx run-many --target=build --watch",
    "serve": "server",
    "bump": "lerna version patch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "git clean -fdX",
    "publish": "npm run build && lerna publish from-package --yes",
    "rewritepackagefiles": "node rewritepackagefiles.js",
    "start": "server --resolve-modules",
    "test": "eslint packages",
    "update": "npm i",
    "upgrade": "syncpack update && syncpack fix && npm i",
    "version": "lerna version"
  },
  "dependencies": {
    "es-module-shims": "^2.8.1"
  },
  "devDependencies": {
    "@damienmortini/eslint-config": "0.0.31",
    "@damienmortini/server": "1.0.87",
    "@damienmortini/typescript-config": "0.0.16",
    "eslint": "10.5.0",
    "fast-glob": "^3.3.3",
    "jsdoc": "^4.0.5",
    "lerna": "^9.0.7",
    "nx": "^22.7.5",
    "nx-cloud": "latest",
    "sort-package-json": "4.0.0",
    "syncpack": "15.3.1",
    "typescript": "6.0.3"
  },
  "optionalDependencies": {
    "@nx/nx-linux-x64-gnu": "22.4.4"
  }
}
