{
  "name": "@damienmortini/lib",
  "version": "0.2.13",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:watch": "pnpm -r run build -- --watch",
    "serve": "server",
    "bump": "lerna version patch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "git clean -fdX",
    "publish": "pnpm run build && lerna publish from-package --yes",
    "rewritepackagefiles": "node rewritepackagefiles.js",
    "start": "server --resolve-modules",
    "test": "eslint packages && pnpm -r run test",
    "update": "pnpm i",
    "upgrade": "syncpack update && syncpack fix && pnpm i",
    "version": "lerna version"
  },
  "dependencies": {
    "es-module-shims": "^2.8.1"
  },
  "devDependencies": {
    "@damienmortini/eslint-config": "0.0.32",
    "@damienmortini/server": "1.0.89",
    "@damienmortini/typescript-config": "0.0.18",
    "eslint": "10.5.0",
    "fast-glob": "^3.3.3",
    "jsdoc": "^4.0.5",
    "lerna": "^9.0.7",
    "sort-package-json": "4.0.0",
    "syncpack": "15.3.1",
    "typescript": "6.0.3"
  }
}
